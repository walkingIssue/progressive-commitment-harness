<div class="model-strip"
     data-model-status-strip="end-user"
     data-model-role-state="@Chat.RoleStatusActiveRole"
     data-provider-health="@Chat.ProviderHealth"
     data-credit-state="@Chat.CreditState"
     data-last-provider-failure="@Chat.LastProviderFailureCode"
     data-live-guard-state="@LiveGuardState">
    <span data-live-mode-state="@Chat.ModeState">@Chat.ModeLabel</span>
    <span data-provider-outcome="@Chat.ProviderOutcome">@Chat.ProviderOutcome.Replace('_', ' ')</span>
    <span data-live-provider-state="@LiveGuardState">@LiveGuardLabel</span>
    <span data-raw-absence-state="@Chat.RawAbsenceState">Raw absence @Chat.RawAbsenceState</span>
</div>

@code {
    [Parameter, EditorRequired]
    public EndUserChatState Chat { get; set; } = default!;

    private string LiveGuardState => Chat.ProviderHealth == "offline_ready"
        ? "blocked_by_guard"
        : "configured";

    private string LiveGuardLabel => Chat.ProviderHealth == "offline_ready"
        ? "Live guarded"
        : "Live configured";
}
