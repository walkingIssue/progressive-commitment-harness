@inject FormBuilder FormBuilder

<section class="form-card primitive-form"
         data-form-builder="validated"
         data-form-id="@Primitive.InstanceId"
         data-manifest-version="@Turn.ManifestVersion"
         data-graph-revision="@Turn.GraphRevision"
         aria-labelledby="@TitleId">
    <div>
        <p class="work-lead">@Primitive.Prompt</p>
        <h2 id="@TitleId">@Primitive.Title</h2>
    </div>
    @foreach (var field in Primitive.Fields)
    {
        var error = ValidationErrors.FirstOrDefault(item => item.FieldId == field.FieldId);
        <label class="form-field"
               data-field-id="@field.FieldId"
               data-field-primitive-id="@field.PrimitiveId"
               data-field-renderer="@field.RendererKey"
               data-field-state="@(error is null ? field.State : "validation_blocked")"
               data-evidence-id="@field.EvidenceId"
               data-error-code="@error?.ErrorCode">
            <span>@field.Label</span>
            @switch (NormalizeRenderer(field.RendererKey))
            {
                case "text_input":
                    <TextInputPrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    break;
                case "textarea":
                    <TextareaPrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    break;
                case "number_input":
                    <NumberPrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    break;
                case "slider":
                    <SliderPrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    break;
                case "date":
                    <DatePrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    break;
                case "date_range":
                    <DateRangePrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    break;
                case "radio_group":
                    @if (field.AllowedValues.Count > 0)
                    {
                        <RadioGroupPrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    }
                    else
                    {
                        <PrimitiveRendererMissing Field="field" RendererKey="radio_group" />
                    }
                    break;
                case "select":
                    @if (field.AllowedValues.Count > 0)
                    {
                        <SelectPrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    }
                    else
                    {
                        <PrimitiveRendererMissing Field="field" RendererKey="select" />
                    }
                    break;
                case "multi_select":
                    @if (field.AllowedValues.Count > 0)
                    {
                        <MultiSelectPrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    }
                    else
                    {
                        <PrimitiveRendererMissing Field="field" RendererKey="multi_select" />
                    }
                    break;
                case "checkbox":
                    <CheckboxPrimitive Field="field" Value="@CurrentValue(field)" ValueChanged="value => SetField(field.FieldId, value)" />
                    break;
                default:
                    <PrimitiveRendererMissing Field="field" RendererKey="@field.RendererKey" />
                    break;
            }
            @if (error is not null)
            {
                <span class="field-error" data-field-error="@field.FieldId">@error.Message</span>
            }
        </label>
    }
    <button type="button"
            class="secondary-button"
            data-answer-submit-local="@Primitive.InstanceId"
            aria-label="Submit local primitive form"
            @onclick="Submit">
        Submit answers
    </button>
</section>

@code {
    [Parameter, EditorRequired]
    public EndUserValidatedTurnView Turn { get; set; } = default!;

    [Parameter, EditorRequired]
    public ValidatedPrimitive Primitive { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<PrimitiveValidationError> ValidationErrors { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback<PrimitiveAnswerDto> OnSubmit { get; set; }

    private readonly Dictionary<string, string> _values = new(StringComparer.Ordinal);

    private string TitleId => $"{Primitive.InstanceId}-title";

    protected override void OnParametersSet()
    {
        foreach (var field in Primitive.Fields)
        {
            _values.TryAdd(field.FieldId, field.Value);
        }
    }

    private string CurrentValue(ValidatedPrimitiveField field) =>
        _values.TryGetValue(field.FieldId, out var value) ? value : field.Value;

    private void SetField(string fieldId, string value)
    {
        _values[fieldId] = value;
    }

    private static string NormalizeRenderer(string rendererKey) =>
        rendererKey.Replace('-', '_');

    private Task Submit()
    {
        var answer = FormBuilder.BuildAnswer(Turn, Primitive, _values);
        return OnSubmit.InvokeAsync(answer);
    }
}
