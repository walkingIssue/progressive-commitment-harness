@foreach (var primitive in Turn.Primitives)
{
    <article class="work-bubble primitive-work @PlanningSessionService.MoodCssClass(primitive.MoodToken)"
             data-primitive-renderer="@primitive.RendererKey"
             data-primitive-id="@primitive.PrimitiveId"
             data-primitive-instance-id="@primitive.InstanceId"
             data-primitive-state="@primitive.State"
             data-mood-token="@primitive.MoodToken"
             data-media-token="@primitive.MediaToken"
             data-media-asset-id="@PlanningSessionService.ResolveMedia(primitive.MediaToken).AssetId"
             data-error-code="@primitive.ErrorCode"
             data-blocked-reason="@primitive.BlockedReason"
             data-raw-absence-state="@Turn.RawAbsenceState">
        @switch (NormalizeRenderer(primitive.RendererKey))
        {
            case "form":
                <FormBuilderView Turn="Turn"
                                 Primitive="primitive"
                                 ValidationErrors="ValidationErrors"
                                 OnSubmit="OnSubmitAnswer" />
                break;
            case "candidate_deck":
                <CandidateDeckPrimitive Primitive="primitive"
                                        SubmitCandidate="candidateId => SubmitCandidateAnswer(primitive, candidateId)" />
                break;
            case "choice_card":
                <ChoiceCardPrimitive Primitive="primitive"
                                     SubmitCandidate="candidateId => SubmitCandidateAnswer(primitive, candidateId)" />
                break;
            case "assistant_message":
                <section class="primitive-assistant-message" data-assistant-message-primitive="@primitive.InstanceId">
                    <p class="work-lead">@primitive.Title</p>
                    <p>@primitive.Prompt</p>
                </section>
                break;
            case "provider_failure":
                <section class="provider-failure primitive-provider-failure"
                         data-provider-failure-primitive="@primitive.InstanceId"
                         data-provider-outcome="@Turn.ProviderOutcome">
                    <p class="work-lead">The live request stopped at a guarded server boundary.</p>
                    <h2>@primitive.Title</h2>
                    <p>@primitive.Prompt</p>
                </section>
                break;
            default:
                <section data-primitive-renderer-blocked="@primitive.RendererKey" data-error-code="unsupported_primitive_renderer">
                    <p class="work-lead">This validated primitive needs a renderer before it can be shown.</p>
                </section>
                break;
        }
    </article>
}

@code {
    [Parameter, EditorRequired]
    public EndUserValidatedTurnView Turn { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<PrimitiveValidationError> ValidationErrors { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback<PrimitiveAnswerDto> OnSubmitAnswer { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string> OnSelectCandidate { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string> OnDeferCandidate { get; set; }

    private static string NormalizeRenderer(string rendererKey) =>
        rendererKey.Replace('-', '_');

    private Task SubmitCandidateAnswer(ValidatedPrimitive primitive, string candidateId)
    {
        var answer = new PrimitiveAnswerDto(
            Turn.SessionId,
            Turn.TurnId,
            Turn.GraphRevision,
            primitive.InstanceId,
            new Dictionary<string, string>(StringComparer.Ordinal)
            {
                ["candidate_id"] = candidateId
            });

        return OnSubmitAnswer.InvokeAsync(answer);
    }
}
