@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject PlanningSessionService PlanningSession
@rendermode InteractiveServer

<section class="chat-shell chat-shell--v18"
         data-end-user-chat="v0"
         data-chat-interactive="true"
         data-deterministic-mode="@Chat.ModeState"
         data-model-role-state="@Chat.RoleStatusActiveRole"
         data-selected-model-role="@Chat.SelectedModelRole"
         data-selected-provider="@Chat.SelectedProvider"
         data-live-preflight-state="@Chat.LivePreflightState"
         data-live-proposal-state="@Chat.LiveProposalState"
         data-harness-validation-state="@Chat.HarnessValidationState"
         data-latest-turn-source="@Chat.LatestTurnSource"
         data-provider-request-state="@Chat.ProviderRequestState"
         data-role-status="@Chat.RoleStatusOutcome"
         data-provider-outcome="@Chat.ProviderOutcome"
         data-validated-turn-id="@CurrentTurn?.TurnId"
         data-validated-turn-source="@CurrentTurn?.Source"
         data-validated-turn-outcome="@CurrentTurn?.OutcomeCode"
         data-manifest-version="@CurrentTurn?.ManifestVersion"
         data-graph-revision="@CurrentTurn?.GraphRevision"
         data-browser-circuit-state="connected"
         data-live-turn-attempt-count="@LiveTurnAttemptCount"
         data-live-second-turn-state="@LiveSecondTurnState"
         data-approval-state="@Chat.ApprovalState"
         data-final-state="@Chat.FinalState"
         data-composer-state="@ComposerState"
         data-ask-drawer="@DrawerState"
         data-focused-turn-id="@FocusedTurnId"
         data-error-code="@Chat.ErrorCode"
         data-blocked-reason="@Chat.BlockedReason"
         data-raw-absence-state="@Chat.RawAbsenceState"
         aria-labelledby="trip-chat-title">
    <aside class="chat-nav" aria-label="Trip planning sections">
        <span class="chat-nav__mark" aria-hidden="true">PC</span>
        <span class="chat-nav__item is-active" aria-hidden="true">Chat</span>
        <a href="/stage-cockpit" class="chat-nav__item" data-engineering-surface-link="stage-cockpit">Stage</a>
    </aside>

    <main class="chat-main" data-agent-work-area="@AgentWorkState">
        <header class="chat-topbar">
            <div>
                <p class="eyebrow">Japan Adventure</p>
                <h1 id="trip-chat-title">Plan with the agent</h1>
            </div>
            <ProviderStatusStrip Chat="Chat" OnModelRoleChanged="SetModelRole" />
        </header>

        <ComposerDrawer Prompt="@Prompt"
                        HasSubmitted="@HasSubmitted"
                        DrawerOpen="@DrawerOpen"
                        RawAbsenceState="@Chat.RawAbsenceState"
                        PromptChanged="SetPrompt"
                        OnSend="SendPromptAsync"
                        OnOpen="OpenDrawer"
                        OnClose="CloseDrawer" />

        <section class="agent-stage"
                 data-transcript="trip"
                 data-turn-count="@Chat.Turns.Count"
                 aria-label="Trip planning transcript">
            @foreach (var turn in Chat.Turns)
            {
                <article class="chat-turn"
                         data-turn-id="@turn.TurnId"
                         data-turn-role="@turn.Role"
                         data-turn-kind="@turn.Kind"
                         data-turn-state="@turn.State"
                         data-turn-focused="@(turn.TurnId == FocusedTurnId ? "true" : "false")"
                         data-outcome-code="@turn.OutcomeCode"
                         data-evidence-id="@turn.EvidenceId"
                         data-candidate-id="@turn.CandidateId"
                         data-candidate-category="@turn.CandidateCategory"
                         data-error-code="@turn.ErrorCode">
                    <div class="chat-turn__meta">
                        <span>@turn.Role</span>
                        <strong>@turn.Kind</strong>
                    </div>
                    @if (turn.Kind == "choice" && turn.CandidateId is not null && SelectedBubble is not null)
                    {
                        <SelectedOptionBubble Bubble="SelectedBubble" />
                    }
                    else
                    {
                        <p>@turn.Text</p>
                    }
                </article>
            }

            <AssistantWorkBubble FormCard="Chat.FormCard" OnSubmitForm="SubmitForm" />

            @if (CurrentTurn is not null)
            {
            <PrimitiveRenderer Turn="CurrentTurn"
                               ValidationErrors="ValidationErrors"
                               OnSubmitAnswer="SubmitPrimitiveAnswer"
                               OnSelectCandidate="SelectCandidate"
                               OnDeferCandidate="DeferCandidate" />
            @if (CurrentTurn.Primitives.Any(primitive => primitive.RendererKey == "form"))
            {
                <button type="button"
                        class="secondary-button primitive-server-submit"
                        data-answer-submit="primitive-trip-basics-form"
                        aria-label="Submit validated primitive form"
                        @onclick="SubmitCurrentPrimitiveAnswer">
                    Submit answers
                </button>
            }
        }

            @if (Chat.ChoiceSet is not null)
            {
                <ChoiceDeck ChoiceSet="Chat.ChoiceSet"
                            DeckIndex="@DeckIndex"
                            OnPrevious="PreviousDeckCard"
                            OnNext="NextDeckCard"
                            OnSelect="SelectCandidate"
                            OnDefer="DeferCandidate" />
            }

            <ApprovalPlateView ApprovalPlate="Chat.ApprovalPlate" OnRequestApproval="RequestApproval" />
            <ProviderFailureNotice ProviderFailure="Chat.ProviderFailure" />
            <EvidencePillStrip Evidence="Chat.Evidence" />
        </section>

        <PlanningTimeline Items="Chat.PlanningTimeline"
                          Mode="@TimelineMode"
                          RawAbsenceState="@Chat.RawAbsenceState"
                          OnModeChanged="SetTimelineMode"
                          OnFocusTurn="FocusTurn" />
    </main>

    <TaskRail Tasks="Chat.Tasks" />
</section>

@code {
    private EndUserChatState Chat { get; set; } = default!;
    private string Prompt { get; set; } = string.Empty;
    private bool HasSubmitted { get; set; }
    private bool DrawerOpen { get; set; }
    private int DeckIndex { get; set; }
    private string TimelineMode { get; set; } = "day";
    private string? FocusedTurnId { get; set; }
    private string SelectedModelRole { get; set; } = EndUserModelRoleSelection.InHarnessActionGenerator;
    private EndUserValidatedTurnView? CurrentTurn { get; set; }
    private PrimitiveAnswerDto? LastPrimitiveAnswer { get; set; }
    private IReadOnlyList<PrimitiveValidationError> ValidationErrors { get; set; } = [];
    private int _liveRequestSerial;

    private string ComposerState => HasSubmitted
        ? DrawerOpen ? "collapsed_drawer_open" : "collapsed_drawer"
        : "expanded_start";

    private string DrawerState => DrawerOpen ? "open" : "closed";

    private string AgentWorkState => HasSubmitted ? "active" : "waiting_for_first_prompt";

    private int LiveTurnAttemptCount =>
        Chat.Turns.Count(turn => turn.Kind is "live-model" or "live-model-followup");

    private string LiveSecondTurnState =>
        Chat.Turns.LastOrDefault(turn => turn.TurnId == "turn-live-model-followup")?.State ?? "not_started";

    private IReadOnlyList<EndUserCandidateOption> CultureCandidates =>
        Chat.ChoiceSet?.Candidates.Where(candidate => candidate.Mood == "reflective-culture").ToArray() ?? [];

    private EndUserSelectedOptionBubble? SelectedBubble
    {
        get
        {
            var selected = Chat.ChoiceSet?.Candidates.SingleOrDefault(candidate => candidate.CandidateId == Chat.ChoiceSet.SelectedCandidateId);
            return selected is null
                ? null
                : new(selected.CandidateId, selected.Category, selected.Mood, selected.MoodTone, selected.Title, selected.Summary, "selected", selected.Media, selected.EvidenceIds);
        }
    }

    protected override void OnInitialized()
    {
        Chat = PlanningSession.CreateInitialState();
        Prompt = Chat.Prompt;
    }

    private void SetPrompt(string prompt)
    {
        Prompt = prompt;
    }

    private async Task SendPromptAsync()
    {
        var role = EndUserModelRoleSelection.Normalize(SelectedModelRole);
        if (role != EndUserModelRoleSelection.DeterministicOffline)
        {
            var promptSnapshot = Prompt;
            var requestSerial = ++_liveRequestSerial;
            HasSubmitted = true;
            DrawerOpen = false;
            DeckIndex = 0;
            FocusedTurnId = "turn-live-model-run";
            Chat = Chat with
            {
                ModeLabel = "Live in-harness pending",
                ModeState = "live-model-pending",
                SelectedModelRole = role,
                SelectedProvider = "openrouter",
                LivePreflightState = "preflight_pending",
                LiveProposalState = "provider_request_pending",
                HarnessValidationState = "not_run",
                LatestTurnSource = "live_provider_pending",
                ProviderRequestState = "attempted",
                ProviderOutcome = "planner_model_pending",
                ProviderHealth = "provider_request_pending",
                Prompt = promptSnapshot,
                ComposerState = "collapsed_drawer",
                FinalState = "pending",
                ErrorCode = null,
                BlockedReason = null
            };
            _ = CompleteLivePromptAsync(promptSnapshot, role, requestSerial);
            await Task.CompletedTask;
            return;
        }

        var result = await PlanningSession.StartAsync(Prompt, SelectedModelRole);
        Chat = result.State;
        CurrentTurn = result.Turn;
        LastPrimitiveAnswer = result.LastAnswer;
        ValidationErrors = result.ValidationErrors;
        SelectedModelRole = Chat.SelectedModelRole;
        Prompt = Chat.Prompt;
        HasSubmitted = true;
        DrawerOpen = false;
        DeckIndex = 0;
        FocusedTurnId = "turn-assistant-final";
    }

    private async Task CompleteLivePromptAsync(string prompt, string role, int requestSerial)
    {
        try
        {
            var result = await PlanningSession.StartAsync(prompt, role);
            await InvokeAsync(() =>
            {
                if (requestSerial != _liveRequestSerial)
                {
                    return;
                }

                Chat = result.State;
                CurrentTurn = result.Turn;
                LastPrimitiveAnswer = result.LastAnswer;
                ValidationErrors = result.ValidationErrors;
                SelectedModelRole = Chat.SelectedModelRole;
                Prompt = Chat.Prompt;
                HasSubmitted = true;
                DrawerOpen = false;
                DeckIndex = 0;
                FocusedTurnId = "turn-assistant-final";
                StateHasChanged();
            });
        }
        catch
        {
            await InvokeAsync(() =>
            {
                Chat = Chat with
                {
                    ModeState = "live-model-blocked",
                    LivePreflightState = "preflight_blocked",
                    LiveProposalState = "provider_blocked",
                    HarnessValidationState = "not_run",
                    LatestTurnSource = "live_provider_blocked",
                    ProviderRequestState = "attempted",
                    ProviderOutcome = "planner_model_provider_unavailable",
                    FinalState = "provider_blocked",
                    ErrorCode = "PCH_UI_LIVE_MODEL_SANITIZED_FAILURE",
                    BlockedReason = "planner_model_provider_unavailable"
                };
                StateHasChanged();
            });
        }
    }

    private void SubmitForm()
    {
        Chat = PlanningSession.SubmitDeterministicForm(Chat);
        FocusedTurnId = "turn-form-submitted";
    }

    private async Task SubmitPrimitiveAnswer(PrimitiveAnswerDto answer)
    {
        if (CurrentTurn is null)
        {
            return;
        }

        var result = await PlanningSession.SubmitAnswer(Chat, CurrentTurn, answer);
        Chat = result.State;
        CurrentTurn = result.Turn;
        LastPrimitiveAnswer = result.LastAnswer;
        ValidationErrors = result.ValidationErrors;
        FocusedTurnId = ValidationErrors.Count == 0 ? "turn-primitive-answer-submitted" : "turn-live-model-run";
    }

    private async Task SubmitCurrentPrimitiveAnswer()
    {
        if (CurrentTurn is null)
        {
            return;
        }

        await SubmitPrimitiveAnswer(PlanningSession.BuildDefaultAnswer(CurrentTurn));
    }

    private void SelectCandidate(string candidateId)
    {
        Chat = PlanningSession.SelectDeterministicCandidate(Chat, candidateId);
        FocusedTurnId = "turn-choice-selected";
    }

    private void DeferCandidate(string candidateId)
    {
        Chat = PlanningSession.DeferDeterministicCandidate(Chat, candidateId);
        FocusedTurnId = "turn-choice-deferred";
    }

    private void RequestApproval()
    {
        Chat = PlanningSession.RequestDeterministicApproval(Chat);
        FocusedTurnId = "turn-approval-blocked";
    }

    private void OpenDrawer()
    {
        DrawerOpen = true;
    }

    private void CloseDrawer()
    {
        DrawerOpen = false;
    }

    private void SetTimelineMode(string mode)
    {
        TimelineMode = mode == "task" ? "task" : "day";
    }

    private void SetModelRole(string role)
    {
        SelectedModelRole = EndUserModelRoleSelection.Normalize(role);
        Chat = PlanningSession.ApplyModelRole(Chat, SelectedModelRole);
        CurrentTurn = null;
        ValidationErrors = [];
    }

    private void FocusTurn(string turnId)
    {
        FocusedTurnId = turnId;
    }

    private void PreviousDeckCard()
    {
        var count = CultureCandidates.Count;
        DeckIndex = count == 0 ? 0 : (DeckIndex + count - 1) % count;
    }

    private void NextDeckCard()
    {
        var count = CultureCandidates.Count;
        DeckIndex = count == 0 ? 0 : (DeckIndex + 1) % count;
    }
}
