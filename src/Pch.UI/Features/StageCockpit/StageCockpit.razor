@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Pch.UI.Features.Approvals
@using Pch.UI.Features.EvidenceTrace
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject HarnessStageCockpitService CockpitService

<main class="pch-shell">
    <section class="stage-hero">
        <div class="stage-hero__copy">
            <p class="eyebrow">Stage cockpit fixture</p>
            <h1>Progressive Commitment Harness</h1>
            <p class="lead">@Fixture.Packet.Summary</p>
        </div>
        <div class="stage-status" aria-label="Current stage summary">
            <span>Stage</span>
            <strong>@Fixture.Packet.Id</strong>
            <small>@Fixture.Packet.CompletedSlotCount of @Fixture.Packet.RequiredSlotCount slots ready</small>
            <small>@Fixture.Packet.Source</small>
        </div>
    </section>

    <section class="stage-workspace" aria-label="Stage cockpit">
        <article class="panel stage-panel">
            <div class="panel-head">
                <span>Stage Packet</span>
                <code>@Fixture.Packet.State</code>
            </div>
            <dl class="packet-list">
                <div>
                    <dt>Goal</dt>
                    <dd>@Fixture.Packet.Summary</dd>
                </div>
                <div>
                    <dt>Allowed outputs</dt>
                    <dd>@string.Join(", ", Fixture.Packet.AllowedOutputs)</dd>
                </div>
                <div>
                    <dt>Authority</dt>
                    <dd>@Fixture.Packet.Authority</dd>
                </div>
            </dl>
        </article>

        <article class="panel form-panel" id="stage-form">
            <div class="panel-head">
                <span>@Fixture.GeneratedForm.Title</span>
                <div class="panel-actions">
                    <button class="ghost" type="button" @onclick="ApplyFormAsync">Apply form</button>
                    <button class="ghost" type="button" @onclick="SaveDraftAsync">Save draft</button>
                </div>
            </div>
            <div class="field-grid">
                @foreach (var field in Fixture.GeneratedForm.Fields)
                {
                    <label data-required="@field.Required.ToString().ToLowerInvariant()">
                        <span>@field.Label</span>
                        @if (field.Kind == "select")
                        {
                            <select value="@FormValues[field.Id]" @onchange="eventArgs => SetFieldValue(field.Id, eventArgs.Value?.ToString())">
                                @foreach (var option in field.Options)
                                {
                                    <option value="@option.Value">@option.Label</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="@field.Kind" value="@FormValues[field.Id]" @onchange="eventArgs => SetFieldValue(field.Id, eventArgs.Value?.ToString())" />
                        }
                    </label>
                }
            </div>
        </article>

        <article class="panel choice-panel">
            <div class="panel-head">
                <span>@Fixture.ChoiceSet.Title</span>
                <small>@Fixture.ChoiceSet.Id</small>
            </div>
            <div class="choice-list">
                @foreach (var candidate in Fixture.ChoiceSet.Candidates)
                {
                    <button class="choice-card @(SelectedCandidateId == candidate.Id ? "selected" : "")"
                            type="button"
                            data-candidate-id="@candidate.Id"
                            @onclick="() => SelectCandidate(candidate.Id)">
                        <strong>@candidate.Title</strong>
                        <span>@candidate.Summary</span>
                        <small>@candidate.Tradeoff</small>
                        <code>@candidate.Id</code>
                    </button>
                }
            </div>
        </article>

        <article class="panel session-panel">
            <div class="panel-head">
                <span>Harness Session Responses</span>
                <small>@Fixture.Session.EndpointHint</small>
            </div>
            <div class="panel-actions response-toolbar">
                <button class="ghost" type="button" @onclick="TriggerBlockedSelection">Trigger blocked choice</button>
                <button class="ghost" type="button" @onclick="RequestApproval">Request approval stage</button>
            </div>
            <div class="response-list" data-session-id="@Fixture.Session.Id">
                @foreach (var response in SessionResponses)
                {
                    <section class="response-card" data-response-id="@response.Id" data-response-state="@response.State" data-target="@response.Target" data-blocked-reason="@(response.State == SessionResponseState.Blocked ? response.Summary : "")">
                        <div>
                            <strong>@response.Label</strong>
                            <p>@response.Summary</p>
                        </div>
                        <code>@response.Id</code>
                        <div class="response-actions">
                            @if (response.State == SessionResponseState.Pending)
                            {
                                <span>Awaiting harness action</span>
                            }
                            else if (response.State == SessionResponseState.ApprovalRequired)
                            {
                                <span data-approval-id="@response.ApprovalId">Approval id: <code>@response.ApprovalId</code></span>
                            }
                            else
                            {
                                <span>@response.State</span>
                            }
                        </div>
                    </section>
                }
            </div>
        </article>

        <article class="panel suggestion-panel">
            <div class="panel-head">
                <span>Model Suggested Action</span>
                <small>@Fixture.SuggestedActions.EndpointHint</small>
            </div>
            <div class="suggestion-list">
                @foreach (var suggestion in Fixture.SuggestedActions.Suggestions)
                {
                    var outcome = Fixture.SuggestedActions.Outcomes.FirstOrDefault(candidate => candidate.SuggestionId == suggestion.Id);
                    <section class="suggestion-card"
                             data-suggestion-id="@suggestion.Id"
                             data-action-kind="@suggestion.ActionKind"
                             data-candidate-id="@suggestion.CandidateId"
                             data-approval-id="@suggestion.ApprovalId"
                             data-trace-outcome="@outcome?.TraceOutcome"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason">
                        <div>
                            <strong>@suggestion.Title</strong>
                            <p>@suggestion.Summary</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.TraceOutcome</small>
                            }
                        </div>
                        <code>@suggestion.ActionKind</code>
                        <button class="ghost" type="button" @onclick="() => ApplySuggestedAction(suggestion.Id)">
                            Apply suggestion
                        </button>
                    </section>
                }
            </div>
        </article>

        <article class="panel model-run-panel">
            <div class="panel-head">
                <span>Run Model Suggestion</span>
                <small>@Fixture.ModelSuggestionRuns.EndpointHint</small>
            </div>
            <div class="model-run-list">
                @foreach (var run in Fixture.ModelSuggestionRuns.Runs)
                {
                    var outcome = Fixture.ModelSuggestionRuns.Outcomes.FirstOrDefault(candidate => candidate.RunId == run.Id);
                    <section class="model-run-card"
                             data-run-model-id="@run.Id"
                             data-action-kind="@(outcome?.ActionKind ?? run.ExpectedActionKind)"
                             data-response-state="@outcome?.State"
                             data-bridge-outcome="@outcome?.BridgeOutcomeCode"
                             data-runtime-decode-outcome="@outcome?.RuntimeDecodeOutcomeCode"
                             data-runtime-intake-outcome="@outcome?.RuntimeIntakeOutcomeCode"
                             data-trace-outcome="@outcome?.TraceOutcome"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason"
                             data-provider="@outcome?.Provider"
                             data-model="@outcome?.Model"
                             data-request-id="@outcome?.RequestId">
                        <div>
                            <strong>@run.Label</strong>
                            <p>@run.ExpectedActionKind</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.TraceOutcome</small>
                            }
                        </div>
                        <code>@(outcome?.ErrorCode ?? run.ExpectedActionKind)</code>
                        <button class="ghost" type="button" @onclick="() => RunModelSuggestion(run.Id)">
                            Run model
                        </button>
                    </section>
                }
            </div>
        </article>

        <article class="panel mission-intake-panel">
            <div class="panel-head">
                <span>Mission Intake</span>
                <small>@Fixture.MissionIntake.EndpointHint</small>
            </div>
            <div class="mission-run-list">
                @foreach (var run in Fixture.MissionIntake.Runs)
                {
                    var outcome = Fixture.MissionIntake.Outcomes.FirstOrDefault(candidate => candidate.RunId == run.Id);
                    <section class="mission-run-card"
                             data-mission-run-id="@run.Id"
                             data-scenario="@run.Scenario"
                             data-proposed-outcome="@outcome?.State"
                             data-provider-runtime-outcome="@outcome?.ProviderRuntimeOutcomeCode"
                             data-adapter-outcome="@outcome?.AdapterOutcomeCode"
                             data-planner-outcome="@outcome?.PlannerOutcomeCode"
                             data-intake-outcome="@outcome?.IntakeOutcomeCode"
                             data-memory-digest-outcome="@outcome?.MemoryDigestOutcomeCode"
                             data-trace-outcome="@outcome?.TraceOutcome"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason"
                             data-provider="@outcome?.Provider"
                             data-model="@outcome?.Model"
                             data-request-id="@outcome?.RequestId">
                        <div>
                            <strong>@run.Label</strong>
                            <p>@run.Scenario</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.TraceOutcome</small>
                            }
                        </div>
                        <code>@(outcome?.ErrorCode ?? run.Scenario)</code>
                        <button class="ghost" type="button" @onclick="() => RunMissionIntake(run.Id)">
                            Run intake
                        </button>
                    </section>
                }
            </div>
            <div class="mission-result-grid">
                <section>
                    <strong>Applied Fields</strong>
                    <div class="mission-list">
                        @foreach (var field in Fixture.MissionIntake.AppliedFields)
                        {
                            <div class="mission-item"
                                 data-applied-field="@field.FieldId"
                                 data-field-source="@field.Source"
                                 data-field-state="@field.State">
                                <span>@field.Label</span>
                                <code>@field.Value</code>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Pending Confirmations</strong>
                    <div class="mission-list">
                        @foreach (var field in Fixture.MissionIntake.PendingConfirmations)
                        {
                            <div class="mission-item"
                                 data-pending-confirmation="@field.FieldId"
                                 data-field-source="@field.Source"
                                 data-field-state="@field.State">
                                <span>@field.Label</span>
                                <code>@field.Value</code>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Commitments</strong>
                    <div class="mission-list">
                        @foreach (var commitment in Fixture.MissionIntake.HighPriorityCommitments)
                        {
                            <div class="mission-item"
                                 data-high-priority-commitment="@commitment.CommitmentId"
                                 data-commitment-kind="@commitment.Kind"
                                 data-commitment-priority="@commitment.Priority"
                                 data-commitment-source="@commitment.Source">
                                <span>@commitment.Title</span>
                                <code>@commitment.Priority</code>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Memory Digest</strong>
                    <div class="mission-list">
                        @foreach (var fact in Fixture.MissionIntake.MemoryDigestFacts)
                        {
                            <div class="mission-item"
                                 data-memory-digest-fact="@fact.FactId"
                                 data-memory-source="@fact.Source"
                                 data-memory-reference="@fact.ReferenceId">
                                <span>@fact.Text</span>
                                <code>@fact.ReferenceId</code>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </article>

        <article class="panel prompt-intake-panel">
            <div class="panel-head">
                <span>Prompt Intake</span>
                <small>@Fixture.PromptIntake.EndpointHint</small>
            </div>
            <div class="mission-run-list">
                @foreach (var run in Fixture.PromptIntake.Runs)
                {
                    var outcome = Fixture.PromptIntake.Outcomes.FirstOrDefault(candidate => candidate.RunId == run.Id);
                    <section class="mission-run-card"
                             data-prompt-run-id="@run.Id"
                             data-scenario="@run.Scenario"
                             data-prompt-packet-outcome="@outcome?.PromptPacketOutcomeCode"
                             data-provider-runtime-outcome="@outcome?.ProviderRuntimeOutcomeCode"
                             data-adapter-outcome="@outcome?.AdapterOutcomeCode"
                             data-intake-outcome="@outcome?.IntakeOutcomeCode"
                             data-memory-digest-outcome="@outcome?.MemoryDigestOutcomeCode"
                             data-trace-outcome="@outcome?.TraceOutcome"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason"
                             data-provider="@outcome?.Provider"
                             data-model="@outcome?.Model"
                             data-request-id="@outcome?.RequestId">
                        <div>
                            <strong>@run.Label</strong>
                            <p>@run.Scenario</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.TraceOutcome</small>
                            }
                        </div>
                        <code>@(outcome?.ErrorCode ?? run.Scenario)</code>
                        <button class="ghost" type="button" @onclick="() => RunPromptIntake(run.Id)">
                            Run prompt
                        </button>
                    </section>
                }
            </div>
            <div class="mission-result-grid">
                <section>
                    <strong>Prompt Applied Fields</strong>
                    <div class="mission-list">
                        @foreach (var field in Fixture.PromptIntake.AppliedFields)
                        {
                            <div class="mission-item"
                                 data-prompt-applied-field="@field.FieldId"
                                 data-field-source="@field.Source"
                                 data-field-state="@field.State">
                                <span>@field.Label</span>
                                <code>@field.Value</code>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Prompt Confirmations</strong>
                    <div class="mission-list">
                        @foreach (var field in Fixture.PromptIntake.PendingConfirmations)
                        {
                            <div class="mission-item"
                                 data-prompt-pending-confirmation="@field.FieldId"
                                 data-field-source="@field.Source"
                                 data-field-state="@field.State">
                                <span>@field.Label</span>
                                <code>@field.Value</code>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Prompt Commitments</strong>
                    <div class="mission-list">
                        @foreach (var commitment in Fixture.PromptIntake.HighPriorityCommitments)
                        {
                            <div class="mission-item"
                                 data-prompt-high-priority-commitment="@commitment.CommitmentId"
                                 data-commitment-kind="@commitment.Kind"
                                 data-commitment-priority="@commitment.Priority"
                                 data-commitment-source="@commitment.Source">
                                <span>@commitment.Title</span>
                                <code>@commitment.Priority</code>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Prompt Digest</strong>
                    <div class="mission-list">
                        @foreach (var fact in Fixture.PromptIntake.MemoryDigestFacts)
                        {
                            <div class="mission-item"
                                 data-prompt-memory-digest-fact="@fact.FactId"
                                 data-memory-source="@fact.Source"
                                 data-memory-reference="@fact.ReferenceId">
                                <span>@fact.Text</span>
                                <code>@fact.ReferenceId</code>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </article>

        <article class="panel itinerary-day-panel">
            <div class="panel-head">
                <span>Itinerary Day Planner</span>
                <small>@Fixture.ItineraryDayPlanner.EndpointHint</small>
            </div>
            <div class="mission-run-list">
                @foreach (var run in Fixture.ItineraryDayPlanner.Runs)
                {
                    var outcome = Fixture.ItineraryDayPlanner.Outcomes.FirstOrDefault(candidate => candidate.RunId == run.Id);
                    <section class="mission-run-card"
                             data-itinerary-run-id="@run.Id"
                             data-scenario="@run.Scenario"
                             data-itinerary-outcome="@outcome?.State"
                             data-day-id="@outcome?.DayId"
                             data-selected-outcome="@outcome?.SelectedOutcome"
                             data-deferred-outcome="@outcome?.DeferredOutcome"
                             data-blocked-outcome="@outcome?.BlockedOutcome"
                             data-hold-outcome="@outcome?.HoldOutcome"
                             data-approval-id="@outcome?.ApprovalId"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason">
                        <div>
                            <strong>@run.Label</strong>
                            <p>@run.Scenario</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.BlockedOutcome</small>
                            }
                        </div>
                        <code>@(outcome?.ErrorCode ?? run.Scenario)</code>
                        <button class="ghost" type="button" @onclick="() => RunItineraryDayPlanner(run.Id)">
                            Run day
                        </button>
                    </section>
                }
            </div>
            <div class="itinerary-grid">
                <section>
                    <strong>Days</strong>
                    <div class="itinerary-list">
                        @foreach (var day in Fixture.ItineraryDayPlanner.Days)
                        {
                            <div class="itinerary-day"
                                 data-itinerary-day-id="@day.DayId"
                                 data-day-date="@day.Date"
                                 data-day-state="@day.State">
                                <span>@day.Date</span>
                                <code>@day.State</code>
                                <div class="itinerary-slot-list">
                                    @foreach (var slot in day.Slots)
                                    {
                                        <div class="itinerary-slot"
                                             data-slot-id="@slot.SlotId"
                                             data-slot-type="@slot.SlotType"
                                             data-slot-state="@slot.State"
                                             data-candidate-pool-id="@slot.CandidatePoolId"
                                             data-selected-candidate-id="@slot.SelectedCandidateId">
                                            <span>@slot.SlotType</span>
                                            <code>@slot.State</code>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Candidate Pools</strong>
                    <div class="itinerary-list">
                        @foreach (var pool in Fixture.ItineraryDayPlanner.CandidatePools)
                        {
                            <div class="candidate-pool"
                                 data-candidate-pool-id="@pool.PoolId"
                                 data-slot-id="@pool.SlotId">
                                <span>@pool.SlotId</span>
                                @foreach (var candidate in pool.Candidates)
                                {
                                    <div class="candidate-option"
                                         data-candidate-id="@candidate.CandidateId"
                                         data-candidate-category="@candidate.Category"
                                         data-evidence-ids="@string.Join(' ', candidate.EvidenceIds)">
                                        <span>@candidate.Title</span>
                                        <code>@candidate.Category</code>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Evidence</strong>
                    <div class="itinerary-list">
                        @foreach (var evidence in Fixture.ItineraryDayPlanner.Evidence)
                        {
                            <div class="itinerary-evidence"
                                 data-itinerary-evidence-id="@evidence.EvidenceId"
                                 data-evidence-source="@evidence.Source"
                                 data-evidence-outcome="@evidence.Outcome">
                                <span>@evidence.EvidenceId</span>
                                <code>@evidence.Outcome</code>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Mock Holds</strong>
                    <div class="itinerary-list">
                        @foreach (var hold in Fixture.ItineraryDayPlanner.Holds)
                        {
                            <div class="itinerary-hold"
                                 data-itinerary-hold-id="@hold.HoldId"
                                 data-slot-id="@hold.SlotId"
                                 data-candidate-id="@hold.CandidateId"
                                 data-approval-id="@hold.ApprovalId"
                                 data-hold-outcome="@hold.Outcome"
                                 data-provider="@hold.Provider"
                                 data-confirmation-id="@hold.ConfirmationId"
                                 data-error-code="@hold.ErrorCode">
                                <span>@hold.Outcome</span>
                                <code>@hold.ApprovalId</code>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Digest</strong>
                    <div class="itinerary-list">
                        @foreach (var fact in Fixture.ItineraryDayPlanner.DigestFacts)
                        {
                            <div class="itinerary-digest"
                                 data-itinerary-digest-fact="@fact.FactId"
                                 data-memory-source="@fact.Source"
                                 data-memory-reference="@fact.ReferenceId">
                                <span>@fact.Text</span>
                                <code>@fact.ReferenceId</code>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </article>

        <article class="panel availability-preview-panel"
                 data-availability-preview="stage-cockpit"
                 data-raw-absence-state="@Fixture.AvailabilityPreview.RawAbsenceState"
                 data-last-availability-run-id="@Fixture.AvailabilityPreview.LastRunId"
                 aria-labelledby="availability-preview-title">
            <div class="panel-head">
                <span id="availability-preview-title">Availability Preview</span>
                <small>@Fixture.AvailabilityPreview.EndpointHint</small>
            </div>
            <section class="release-summary"
                     role="status"
                     aria-live="polite"
                     data-availability-summary="stage-cockpit"
                     data-raw-absence-state="@Fixture.AvailabilityPreview.RawAbsenceState"
                     data-last-availability-run-id="@Fixture.AvailabilityPreview.LastRunId">
                <div>
                    <strong>Preview</strong>
                    <span>@(Fixture.AvailabilityPreview.LastRunId ?? "not-run")</span>
                </div>
                <dl>
                    <div>
                        <dt>Quote-ready</dt>
                        <dd>@Fixture.AvailabilityPreview.Outcomes.Count(outcome => outcome.State == "quote-ready")</dd>
                    </div>
                    <div>
                        <dt>Blocked</dt>
                        <dd>@Fixture.AvailabilityPreview.Outcomes.Count(outcome => outcome.State.Contains("blocked", StringComparison.Ordinal))</dd>
                    </div>
                    <div>
                        <dt>Raw</dt>
                        <dd>@Fixture.AvailabilityPreview.RawAbsenceState</dd>
                    </div>
                </dl>
            </section>
            <div class="availability-run-list">
                @foreach (var run in Fixture.AvailabilityPreview.Runs)
                {
                    var outcome = Fixture.AvailabilityPreview.Outcomes.FirstOrDefault(candidate => candidate.RunId == run.Id);
                    <section class="availability-card"
                             id="@run.MarkerId"
                             data-availability-run-id="@run.Id"
                             data-availability-scenario="@run.Scenario"
                             data-availability-state="@outcome?.State"
                             data-slot-id="@(outcome?.SlotId ?? run.SlotId)"
                             data-candidate-id="@(outcome?.CandidateId ?? run.CandidateId)"
                             data-quote-category="@(outcome?.QuoteCategory ?? run.QuoteCategory)"
                             data-provider-outcome="@outcome?.ProviderOutcomeCode"
                             data-harness-outcome="@outcome?.HarnessOutcomeCode"
                             data-approval-outcome="@outcome?.ApprovalOutcomeCode"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason"
                             data-provider="@outcome?.Provider"
                             data-model="@outcome?.Model"
                             data-request-id="@outcome?.RequestId"
                             data-raw-absence-state="@Fixture.AvailabilityPreview.RawAbsenceState">
                        <div>
                            <strong>@run.Label</strong>
                            <p>@run.Scenario</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.ProviderOutcomeCode</small>
                            }
                        </div>
                        <code>@(outcome?.ErrorCode ?? run.QuoteCategory)</code>
                        <button id="@run.ControlId"
                                class="ghost"
                                type="button"
                                aria-label="@run.ControlAriaLabel"
                                aria-controls="@run.MarkerId"
                                data-availability-control-id="@run.ControlId"
                                @onclick="() => RunAvailabilityPreview(run.Id)">
                            Preview
                        </button>
                    </section>
                }
            </div>
            <div class="availability-grid">
                <section>
                    <strong>Quote Rows</strong>
                    <div class="availability-list">
                        @foreach (var quote in Fixture.AvailabilityPreview.Quotes)
                        {
                            <div class="availability-quote"
                                 data-availability-quote-id="@quote.QuoteId"
                                 data-availability-run-id="@quote.RunId"
                                 data-slot-id="@quote.SlotId"
                                 data-candidate-id="@quote.CandidateId"
                                 data-quote-category="@quote.QuoteCategory"
                                 data-provider="@quote.Provider"
                                 data-price-state="@quote.PriceState"
                                 data-availability-quote-state="@quote.Outcome"
                                 data-expires-at="@quote.ExpiresAt">
                                <span>@quote.QuoteCategory</span>
                                <code>@quote.Outcome</code>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </article>

        <article class="panel end-to-end-trip-panel"
                 data-release-smoke-surface="stage-cockpit-e2e"
                 data-release-summary-state="@Fixture.EndToEndTripRuns.ReleaseSummary.State"
                 aria-labelledby="release-smoke-title">
            <div class="panel-head">
                <span id="release-smoke-title">End-to-End Trip Run</span>
                <small>@Fixture.EndToEndTripRuns.EndpointHint</small>
            </div>
            <section class="release-summary"
                     role="status"
                     aria-live="polite"
                     data-release-summary-id="@Fixture.EndToEndTripRuns.ReleaseSummary.SummaryId"
                     data-release-summary-state="@Fixture.EndToEndTripRuns.ReleaseSummary.State"
                     data-release-primary-run-id="@Fixture.EndToEndTripRuns.ReleaseSummary.PrimaryRunId"
                     data-prompt-packet-outcome="@Fixture.EndToEndTripRuns.ReleaseSummary.PromptPacketOutcomeCode"
                     data-mission-outcome="@Fixture.EndToEndTripRuns.ReleaseSummary.MissionOutcomeCode"
                     data-itinerary-outcome="@Fixture.EndToEndTripRuns.ReleaseSummary.ItineraryOutcomeCode"
                     data-snapshot-outcome="@Fixture.EndToEndTripRuns.ReleaseSummary.SnapshotOutcomeCode"
                     data-evidence-export-outcome="@Fixture.EndToEndTripRuns.ReleaseSummary.EvidenceExportOutcomeCode"
                     data-hold-outcome="@Fixture.EndToEndTripRuns.ReleaseSummary.HoldOutcomeCode"
                     data-approval-id="@Fixture.EndToEndTripRuns.ReleaseSummary.ApprovalId"
                     data-evidence-packet-id="@Fixture.EndToEndTripRuns.ReleaseSummary.EvidencePacketId"
                     data-export-packet-id="@Fixture.EndToEndTripRuns.ReleaseSummary.ExportPacketId"
                     data-accepted-path-count="@Fixture.EndToEndTripRuns.ReleaseSummary.AcceptedPathCount"
                     data-blocked-path-count="@Fixture.EndToEndTripRuns.ReleaseSummary.BlockedPathCount"
                     data-pending-path-count="@Fixture.EndToEndTripRuns.ReleaseSummary.PendingPathCount"
                     data-raw-absence-marker="@Fixture.EndToEndTripRuns.ReleaseSummary.RawAbsenceMarker">
                <div>
                    <strong>Release Summary</strong>
                    <span>@Fixture.EndToEndTripRuns.ReleaseSummary.State</span>
                </div>
                <dl>
                    <div>
                        <dt>Snapshot</dt>
                        <dd>@Fixture.EndToEndTripRuns.ReleaseSummary.SnapshotOutcomeCode</dd>
                    </div>
                    <div>
                        <dt>Export</dt>
                        <dd>@Fixture.EndToEndTripRuns.ReleaseSummary.EvidenceExportOutcomeCode</dd>
                    </div>
                    <div>
                        <dt>Paths</dt>
                        <dd>@Fixture.EndToEndTripRuns.ReleaseSummary.AcceptedPathCount / @Fixture.EndToEndTripRuns.ReleaseSummary.BlockedPathCount / @Fixture.EndToEndTripRuns.ReleaseSummary.PendingPathCount</dd>
                    </div>
                </dl>
                <div class="release-path-list">
                    @foreach (var path in Fixture.EndToEndTripRuns.ReleaseSummary.Paths)
                    {
                        <div class="release-path"
                             data-release-path-run-id="@path.RunId"
                             data-release-path-scenario="@path.Scenario"
                             data-release-expected-state="@path.ExpectedState"
                             data-release-observed-state="@path.ObservedState"
                             data-release-marker="@path.MarkerId"
                             data-release-control-id="@path.ControlId"
                             data-error-code="@path.ErrorCode"
                             data-blocked-reason="@path.BlockedReason">
                            <span>@path.RunId</span>
                            <code>@path.ObservedState</code>
                        </div>
                    }
                </div>
            </section>
            <div class="mission-run-list">
                @foreach (var run in Fixture.EndToEndTripRuns.Runs)
                {
                    var outcome = Fixture.EndToEndTripRuns.Outcomes.FirstOrDefault(candidate => candidate.RunId == run.Id);
                    var path = Fixture.EndToEndTripRuns.ReleaseSummary.Paths.FirstOrDefault(candidate => candidate.RunId == run.Id);
                    <section class="mission-run-card"
                             id="@run.ReleaseMarker"
                             data-run-id="@run.Id"
                             data-e2e-run-id="@run.Id"
                             data-release-smoke-run-id="@run.Id"
                             data-release-smoke-marker="@run.ReleaseMarker"
                             data-release-control-id="@run.ControlId"
                             data-release-expected-state="@path?.ExpectedState"
                             data-release-observed-state="@path?.ObservedState"
                             data-scenario="@run.Scenario"
                             data-e2e-state="@outcome?.State"
                             data-prompt-packet-outcome="@outcome?.PromptPacketOutcomeCode"
                             data-mission-outcome="@outcome?.MissionOutcomeCode"
                             data-itinerary-outcome="@outcome?.ItineraryOutcomeCode"
                             data-memory-digest-outcome="@outcome?.MemoryDigestOutcomeCode"
                             data-trace-outcome="@outcome?.TraceOutcome"
                             data-selected-count="@outcome?.SelectedCount"
                             data-deferred-count="@outcome?.DeferredCount"
                             data-hold-outcome="@outcome?.HoldOutcomeCode"
                             data-approval-id="@outcome?.ApprovalId"
                             data-snapshot-outcome="@outcome?.SnapshotOutcomeCode"
                             data-evidence-export-outcome="@outcome?.EvidenceExportOutcomeCode"
                             data-evidence-packet-id="@outcome?.EvidencePacketId"
                             data-export-packet-id="@outcome?.ExportPacketId"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason"
                             data-provider="@outcome?.Provider"
                             data-model="@outcome?.Model"
                             data-request-id="@outcome?.RequestId">
                        <div>
                            <strong>@run.Label</strong>
                            <p>@run.Scenario</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.TraceOutcome</small>
                            }
                        </div>
                        <code>@(outcome?.ErrorCode ?? run.Scenario)</code>
                        <button id="@run.ControlId"
                                class="ghost"
                                type="button"
                                aria-label="@run.ControlAriaLabel"
                                aria-controls="@run.ReleaseMarker"
                                data-release-control-id="@run.ControlId"
                                @onclick="() => RunEndToEndTrip(run.Id)">
                            Run trip
                        </button>
                    </section>
                }
            </div>
            <div class="itinerary-grid">
                <section>
                    <strong>Evidence Export</strong>
                    <div class="itinerary-list">
                        @foreach (var evidence in Fixture.EndToEndTripRuns.Evidence)
                        {
                            <div class="itinerary-evidence"
                                 data-e2e-evidence-id="@evidence.EvidenceId"
                                 data-e2e-run-id="@evidence.RunId"
                                 data-export-packet-id="@evidence.ExportPacketId"
                                 data-evidence-outcome="@evidence.Outcome"
                                 data-evidence-reference="@evidence.ReferenceId">
                                <span>@evidence.Outcome</span>
                                <code>@evidence.EvidenceId</code>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </article>

        <article class="panel fidelity-release-panel"
                 data-fidelity-dashboard="stage-6-release"
                 data-fidelity-matrix-state="@Fixture.FidelityReleaseDashboard.MatrixState"
                 data-release-gate-state="@Fixture.FidelityReleaseDashboard.ReleaseGateState"
                 data-replay-coverage-state="@Fixture.FidelityReleaseDashboard.ReplayCoverageState"
                 data-fallback-count="@Fixture.FidelityReleaseDashboard.FallbackCount"
                 data-schema-validity-count="@Fixture.FidelityReleaseDashboard.SchemaValidityCount"
                 data-unsupported-claim-count="@Fixture.FidelityReleaseDashboard.UnsupportedClaimCount"
                 data-raw-absence-state="@Fixture.FidelityReleaseDashboard.RawAbsenceState"
                 data-last-checked-row-id="@Fixture.FidelityReleaseDashboard.LastCheckedRowId"
                 aria-labelledby="fidelity-release-title">
            <div class="panel-head">
                <span id="fidelity-release-title">Release Fidelity</span>
                <small>@Fixture.FidelityReleaseDashboard.EndpointHint</small>
            </div>
            <section class="release-summary"
                     role="status"
                     aria-live="polite"
                     data-fidelity-summary="stage-6"
                     data-fidelity-matrix-state="@Fixture.FidelityReleaseDashboard.MatrixState"
                     data-release-gate-state="@Fixture.FidelityReleaseDashboard.ReleaseGateState"
                     data-fallback-count="@Fixture.FidelityReleaseDashboard.FallbackCount"
                     data-schema-validity-count="@Fixture.FidelityReleaseDashboard.SchemaValidityCount"
                     data-unsupported-claim-count="@Fixture.FidelityReleaseDashboard.UnsupportedClaimCount"
                     data-raw-absence-state="@Fixture.FidelityReleaseDashboard.RawAbsenceState">
                <div>
                    <strong>Gate</strong>
                    <span>@Fixture.FidelityReleaseDashboard.ReleaseGateState</span>
                </div>
                <dl>
                    <div>
                        <dt>Matrix</dt>
                        <dd>@Fixture.FidelityReleaseDashboard.MatrixState</dd>
                    </div>
                    <div>
                        <dt>Replay</dt>
                        <dd>@Fixture.FidelityReleaseDashboard.ReplayCoverageState</dd>
                    </div>
                    <div>
                        <dt>Claims</dt>
                        <dd>@Fixture.FidelityReleaseDashboard.UnsupportedClaimCount</dd>
                    </div>
                </dl>
            </section>
            <div class="fidelity-grid">
                <section>
                    <strong>Ownership Matrix</strong>
                    <div class="fidelity-list">
                        @foreach (var row in Fixture.FidelityReleaseDashboard.OwnershipRows)
                        {
                            var outcome = Fixture.FidelityReleaseDashboard.CheckOutcomes.FirstOrDefault(candidate => candidate.RowId == row.RowId);
                            <div class="fidelity-row"
                                 id="@row.MarkerId"
                                 data-fidelity-row-id="@row.RowId"
                                 data-stage-id="@row.StageId"
                                 data-stage-ownership="@row.Ownership"
                                 data-fidelity-matrix-state="@row.MatrixState"
                                 data-replay-coverage-state="@row.ReplayCoverageState"
                                 data-fallback-count="@row.FallbackCount"
                                 data-schema-validity-count="@row.SchemaValidityCount"
                                 data-unsupported-claim-count="@row.UnsupportedClaimCount"
                                 data-release-gate-state="@row.ReleaseGateState"
                                 data-raw-absence-state="@row.RawAbsenceState"
                                 data-blocked-reason="@row.BlockedReason"
                                 data-fidelity-check-state="@outcome?.State"
                                 data-error-code="@outcome?.ErrorCode">
                                <div>
                                    <span>@row.StageLabel</span>
                                    <code>@row.Ownership</code>
                                </div>
                                <button id="@row.ControlId"
                                        class="ghost"
                                        type="button"
                                        aria-label="@row.ControlAriaLabel"
                                        aria-controls="@row.MarkerId"
                                        data-fidelity-control-id="@row.ControlId"
                                        @onclick="() => RunFidelityReleaseCheck(row.RowId)">
                                    Check row
                                </button>
                            </div>
                        }
                    </div>
                </section>
                <section>
                    <strong>Eval Artifacts</strong>
                    <div class="fidelity-list">
                        @foreach (var artifact in Fixture.FidelityReleaseDashboard.EvalArtifacts)
                        {
                            <div class="fidelity-artifact"
                                 data-eval-artifact-id="@artifact.ArtifactId"
                                 data-provider="@artifact.Provider"
                                 data-eval-artifact-status="@artifact.Outcome"
                                 data-schema-validity-state="@artifact.SchemaValidityState"
                                 data-schema-validity-count="@artifact.SchemaValidCount"
                                 data-unsupported-claim-count="@artifact.UnsupportedClaimCount"
                                 data-raw-absence-state="@artifact.RawAbsenceState"
                                 data-error-code="@artifact.ErrorCode">
                                <span>@artifact.Label</span>
                                <code>@artifact.Outcome</code>
                            </div>
                        }
                    </div>
                </section>
            </div>
        </article>

        <ApprovalGate Approval="Fixture.Approval"
                      Response="ApprovalResponse"
                      ApprovalToken="@ApprovalToken"
                      OnApprove="ApproveCurrentRequest" />

        <EvidenceTracePreview Trace="Fixture.Trace" Claims="TraceClaims.ToArray()" />
    </section>
</main>

@code {
    private StageCockpitFixture Fixture = default!;
    private readonly Dictionary<string, string> FormValues = [];
    private IJSObjectReference? module;
    private List<SessionResponseFixture> SessionResponses = [];
    private string SelectedCandidateId = "";
    private string ApprovalToken = "";

    private SessionResponseFixture ApprovalResponse =>
        SessionResponses.FirstOrDefault(response => response.ApprovalId == Fixture.Approval.Id)
        ?? new(
            "response.pending.approval",
            SessionResponseState.Pending,
            "Pending",
            "No approval request is active for the current harness stage.",
            Fixture.Approval.Id,
            Fixture.Approval.Id);

    private IEnumerable<EvidenceClaimFixture> TraceClaims =>
    [
        ..Fixture.Trace.Claims.Where(claim => claim.Id != "claim.choice" && claim.Id != "claim.approval"),
        new("claim.choice", $"Selected candidate remains {SelectedCandidateId}", "fixture", SelectedCandidateId),
        new("claim.approval", ApprovalToken.Length > 0 ? "Fixture hold is approved for adapter handoff" : "Fixture hold is waiting for approval", "ui-state", Fixture.Approval.Id)
    ];

    protected override void OnInitialized()
    {
        Fixture = CockpitService.Current();
        LoadFixtureState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/forms.js");
        await module.InvokeVoidAsync("focusFirstField", "#stage-form");
        await module.InvokeVoidAsync("markRequiredSummary", "#stage-form", ".stage-status small");
    }

    private void SetFieldValue(string id, string? value)
    {
        FormValues[id] = value ?? "";
    }

    private Task ApplyFormAsync()
    {
        Fixture = CockpitService.ApplyForm(FormValues);
        LoadFixtureState();
        return Task.CompletedTask;
    }

    private void SelectCandidate(string candidateId)
    {
        Fixture = CockpitService.SelectCandidate(candidateId);
        LoadFixtureState();
    }

    private void TriggerBlockedSelection()
    {
        Fixture = CockpitService.TriggerBlockedSelection();
        LoadFixtureState();
    }

    private void RequestApproval()
    {
        Fixture = CockpitService.RequestApprovalStage();
        LoadFixtureState();
    }

    private void ApplySuggestedAction(string suggestionId)
    {
        Fixture = CockpitService.ApplySuggestedAction(suggestionId);
        LoadFixtureState();
    }

    private void RunModelSuggestion(string runId)
    {
        Fixture = CockpitService.RunModelSuggestion(runId);
        LoadFixtureState();
    }

    private void RunMissionIntake(string runId)
    {
        Fixture = CockpitService.RunMissionIntake(runId);
        LoadFixtureState();
    }

    private void RunPromptIntake(string runId)
    {
        Fixture = CockpitService.RunPromptIntake(runId);
        LoadFixtureState();
    }

    private void RunItineraryDayPlanner(string runId)
    {
        Fixture = CockpitService.RunItineraryDayPlanner(runId);
        LoadFixtureState();
    }

    private void RunEndToEndTrip(string runId)
    {
        Fixture = CockpitService.RunEndToEndTrip(runId);
        LoadFixtureState();
    }

    private void RunAvailabilityPreview(string runId)
    {
        Fixture = CockpitService.RunAvailabilityPreview(runId);
        LoadFixtureState();
    }

    private void RunFidelityReleaseCheck(string rowId)
    {
        Fixture = CockpitService.RunFidelityReleaseCheck(rowId);
        LoadFixtureState();
    }

    private async Task SaveDraftAsync()
    {
        if (module is null) return;

        var values = FormValues.ToDictionary(
            pair => pair.Key,
            object? (pair) => pair.Value);
        values["selectedCandidateId"] = SelectedCandidateId;
        values["responseStates"] = string.Join(",", SessionResponses.Select(response => $"{response.Id}:{response.State}"));

        await module.InvokeVoidAsync("saveDraft", Fixture.Packet.Id, values);
    }

    private void ApproveCurrentRequest()
    {
        Fixture = CockpitService.ApproveCurrentRequest();
        ApprovalToken = $"ui-approval-present-{DateTimeOffset.UtcNow:yyyyMMddHHmmss}";
        LoadFixtureState();
    }

    private void LoadFixtureState()
    {
        FormValues.Clear();
        foreach (var field in Fixture.GeneratedForm.Fields)
        {
            FormValues[field.Id] = field.Value;
        }

        SelectedCandidateId = Fixture.ChoiceSet.SelectedCandidateId;
        SessionResponses = [.. Fixture.Session.Responses];
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}
