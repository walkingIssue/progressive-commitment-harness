@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using Pch.UI.Features.Approvals
@using Pch.UI.Features.EvidenceTrace
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject HarnessStageCockpitService CockpitService

<main class="pch-shell">
    <section class="stage-hero">
        <div class="stage-hero__copy">
            <p class="eyebrow">Stage cockpit fixture</p>
            <h1>Progressive Commitment Harness</h1>
            <p class="lead">@Fixture.Packet.Summary</p>
        </div>
        <div class="stage-status" aria-label="Current stage summary">
            <span>Stage</span>
            <strong>@Fixture.Packet.Id</strong>
            <small>@Fixture.Packet.CompletedSlotCount of @Fixture.Packet.RequiredSlotCount slots ready</small>
            <small>@Fixture.Packet.Source</small>
        </div>
    </section>

    <section class="stage-workspace" aria-label="Stage cockpit">
        <article class="panel stage-panel">
            <div class="panel-head">
                <span>Stage Packet</span>
                <code>@Fixture.Packet.State</code>
            </div>
            <dl class="packet-list">
                <div>
                    <dt>Goal</dt>
                    <dd>@Fixture.Packet.Summary</dd>
                </div>
                <div>
                    <dt>Allowed outputs</dt>
                    <dd>@string.Join(", ", Fixture.Packet.AllowedOutputs)</dd>
                </div>
                <div>
                    <dt>Authority</dt>
                    <dd>@Fixture.Packet.Authority</dd>
                </div>
            </dl>
        </article>

        <article class="panel form-panel" id="stage-form">
            <div class="panel-head">
                <span>@Fixture.GeneratedForm.Title</span>
                <div class="panel-actions">
                    <button class="ghost" type="button" @onclick="ApplyFormAsync">Apply form</button>
                    <button class="ghost" type="button" @onclick="SaveDraftAsync">Save draft</button>
                </div>
            </div>
            <div class="field-grid">
                @foreach (var field in Fixture.GeneratedForm.Fields)
                {
                    <label data-required="@field.Required.ToString().ToLowerInvariant()">
                        <span>@field.Label</span>
                        @if (field.Kind == "select")
                        {
                            <select value="@FormValues[field.Id]" @onchange="eventArgs => SetFieldValue(field.Id, eventArgs.Value?.ToString())">
                                @foreach (var option in field.Options)
                                {
                                    <option value="@option.Value">@option.Label</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="@field.Kind" value="@FormValues[field.Id]" @onchange="eventArgs => SetFieldValue(field.Id, eventArgs.Value?.ToString())" />
                        }
                    </label>
                }
            </div>
        </article>

        <article class="panel choice-panel">
            <div class="panel-head">
                <span>@Fixture.ChoiceSet.Title</span>
                <small>@Fixture.ChoiceSet.Id</small>
            </div>
            <div class="choice-list">
                @foreach (var candidate in Fixture.ChoiceSet.Candidates)
                {
                    <button class="choice-card @(SelectedCandidateId == candidate.Id ? "selected" : "")"
                            type="button"
                            data-candidate-id="@candidate.Id"
                            @onclick="() => SelectCandidate(candidate.Id)">
                        <strong>@candidate.Title</strong>
                        <span>@candidate.Summary</span>
                        <small>@candidate.Tradeoff</small>
                        <code>@candidate.Id</code>
                    </button>
                }
            </div>
        </article>

        <article class="panel session-panel">
            <div class="panel-head">
                <span>Harness Session Responses</span>
                <small>@Fixture.Session.EndpointHint</small>
            </div>
            <div class="panel-actions response-toolbar">
                <button class="ghost" type="button" @onclick="TriggerBlockedSelection">Trigger blocked choice</button>
                <button class="ghost" type="button" @onclick="RequestApproval">Request approval stage</button>
            </div>
            <div class="response-list" data-session-id="@Fixture.Session.Id">
                @foreach (var response in SessionResponses)
                {
                    <section class="response-card" data-response-id="@response.Id" data-response-state="@response.State" data-target="@response.Target" data-blocked-reason="@(response.State == SessionResponseState.Blocked ? response.Summary : "")">
                        <div>
                            <strong>@response.Label</strong>
                            <p>@response.Summary</p>
                        </div>
                        <code>@response.Id</code>
                        <div class="response-actions">
                            @if (response.State == SessionResponseState.Pending)
                            {
                                <span>Awaiting harness action</span>
                            }
                            else if (response.State == SessionResponseState.ApprovalRequired)
                            {
                                <span data-approval-id="@response.ApprovalId">Approval id: <code>@response.ApprovalId</code></span>
                            }
                            else
                            {
                                <span>@response.State</span>
                            }
                        </div>
                    </section>
                }
            </div>
        </article>

        <article class="panel suggestion-panel">
            <div class="panel-head">
                <span>Model Suggested Action</span>
                <small>@Fixture.SuggestedActions.EndpointHint</small>
            </div>
            <div class="suggestion-list">
                @foreach (var suggestion in Fixture.SuggestedActions.Suggestions)
                {
                    var outcome = Fixture.SuggestedActions.Outcomes.FirstOrDefault(candidate => candidate.SuggestionId == suggestion.Id);
                    <section class="suggestion-card"
                             data-suggestion-id="@suggestion.Id"
                             data-action-kind="@suggestion.ActionKind"
                             data-candidate-id="@suggestion.CandidateId"
                             data-approval-id="@suggestion.ApprovalId"
                             data-trace-outcome="@outcome?.TraceOutcome"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason">
                        <div>
                            <strong>@suggestion.Title</strong>
                            <p>@suggestion.Summary</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.TraceOutcome</small>
                            }
                        </div>
                        <code>@suggestion.ActionKind</code>
                        <button class="ghost" type="button" @onclick="() => ApplySuggestedAction(suggestion.Id)">
                            Apply suggestion
                        </button>
                    </section>
                }
            </div>
        </article>

        <article class="panel model-run-panel">
            <div class="panel-head">
                <span>Run Model Suggestion</span>
                <small>@Fixture.ModelSuggestionRuns.EndpointHint</small>
            </div>
            <div class="model-run-list">
                @foreach (var run in Fixture.ModelSuggestionRuns.Runs)
                {
                    var outcome = Fixture.ModelSuggestionRuns.Outcomes.FirstOrDefault(candidate => candidate.RunId == run.Id);
                    <section class="model-run-card"
                             data-run-model-id="@run.Id"
                             data-action-kind="@(outcome?.ActionKind ?? run.ExpectedActionKind)"
                             data-response-state="@outcome?.State"
                             data-bridge-outcome="@outcome?.BridgeOutcomeCode"
                             data-runtime-decode-outcome="@outcome?.RuntimeDecodeOutcomeCode"
                             data-runtime-intake-outcome="@outcome?.RuntimeIntakeOutcomeCode"
                             data-trace-outcome="@outcome?.TraceOutcome"
                             data-error-code="@outcome?.ErrorCode"
                             data-blocked-reason="@outcome?.BlockedReason"
                             data-provider="@outcome?.Provider"
                             data-model="@outcome?.Model"
                             data-request-id="@outcome?.RequestId">
                        <div>
                            <strong>@run.Label</strong>
                            <p>@run.ExpectedActionKind</p>
                            @if (outcome is not null)
                            {
                                <small>@outcome.State / @outcome.TraceOutcome</small>
                            }
                        </div>
                        <code>@(outcome?.ErrorCode ?? run.ExpectedActionKind)</code>
                        <button class="ghost" type="button" @onclick="() => RunModelSuggestion(run.Id)">
                            Run model
                        </button>
                    </section>
                }
            </div>
        </article>

        <ApprovalGate Approval="Fixture.Approval"
                      Response="ApprovalResponse"
                      ApprovalToken="@ApprovalToken"
                      OnApprove="ApproveCurrentRequest" />

        <EvidenceTracePreview Trace="Fixture.Trace" Claims="TraceClaims.ToArray()" />
    </section>
</main>

@code {
    private StageCockpitFixture Fixture = default!;
    private readonly Dictionary<string, string> FormValues = [];
    private IJSObjectReference? module;
    private List<SessionResponseFixture> SessionResponses = [];
    private string SelectedCandidateId = "";
    private string ApprovalToken = "";

    private SessionResponseFixture ApprovalResponse =>
        SessionResponses.FirstOrDefault(response => response.ApprovalId == Fixture.Approval.Id)
        ?? new(
            "response.pending.approval",
            SessionResponseState.Pending,
            "Pending",
            "No approval request is active for the current harness stage.",
            Fixture.Approval.Id,
            Fixture.Approval.Id);

    private IEnumerable<EvidenceClaimFixture> TraceClaims =>
    [
        ..Fixture.Trace.Claims.Where(claim => claim.Id != "claim.choice" && claim.Id != "claim.approval"),
        new("claim.choice", $"Selected candidate remains {SelectedCandidateId}", "fixture", SelectedCandidateId),
        new("claim.approval", ApprovalToken.Length > 0 ? "Fixture hold is approved for adapter handoff" : "Fixture hold is waiting for approval", "ui-state", Fixture.Approval.Id)
    ];

    protected override void OnInitialized()
    {
        Fixture = CockpitService.Current();
        LoadFixtureState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/forms.js");
        await module.InvokeVoidAsync("focusFirstField", "#stage-form");
        await module.InvokeVoidAsync("markRequiredSummary", "#stage-form", ".stage-status small");
    }

    private void SetFieldValue(string id, string? value)
    {
        FormValues[id] = value ?? "";
    }

    private Task ApplyFormAsync()
    {
        Fixture = CockpitService.ApplyForm(FormValues);
        LoadFixtureState();
        return Task.CompletedTask;
    }

    private void SelectCandidate(string candidateId)
    {
        Fixture = CockpitService.SelectCandidate(candidateId);
        LoadFixtureState();
    }

    private void TriggerBlockedSelection()
    {
        Fixture = CockpitService.TriggerBlockedSelection();
        LoadFixtureState();
    }

    private void RequestApproval()
    {
        Fixture = CockpitService.RequestApprovalStage();
        LoadFixtureState();
    }

    private void ApplySuggestedAction(string suggestionId)
    {
        Fixture = CockpitService.ApplySuggestedAction(suggestionId);
        LoadFixtureState();
    }

    private void RunModelSuggestion(string runId)
    {
        Fixture = CockpitService.RunModelSuggestion(runId);
        LoadFixtureState();
    }

    private async Task SaveDraftAsync()
    {
        if (module is null) return;

        var values = FormValues.ToDictionary(
            pair => pair.Key,
            object? (pair) => pair.Value);
        values["selectedCandidateId"] = SelectedCandidateId;
        values["responseStates"] = string.Join(",", SessionResponses.Select(response => $"{response.Id}:{response.State}"));

        await module.InvokeVoidAsync("saveDraft", Fixture.Packet.Id, values);
    }

    private void ApproveCurrentRequest()
    {
        Fixture = CockpitService.ApproveCurrentRequest();
        ApprovalToken = $"ui-approval-present-{DateTimeOffset.UtcNow:yyyyMMddHHmmss}";
        LoadFixtureState();
    }

    private void LoadFixtureState()
    {
        FormValues.Clear();
        foreach (var field in Fixture.GeneratedForm.Fields)
        {
            FormValues[field.Id] = field.Value;
        }

        SelectedCandidateId = Fixture.ChoiceSet.SelectedCandidateId;
        SessionResponses = [.. Fixture.Session.Responses];
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}
