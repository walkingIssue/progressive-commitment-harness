@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Progressive Commitment Harness</PageTitle>

<main class="pch-shell">
    <section class="hero-band">
        <div>
            <p class="eyebrow">Stage cockpit shell</p>
            <h1>Progressive Commitment Harness</h1>
            <p class="lead">
                A UI-first harness for collapsing messy trip intent into stage-local forms,
                choices, approvals, and evidence.
            </p>
        </div>
        <div class="stage-status">
            <span>Stage</span>
            <strong>@StageId</strong>
            <small>@RequiredCount required fields</small>
        </div>
    </section>

    <section class="workspace-grid">
        <article class="panel stage-panel">
            <div class="panel-head">
                <span>Stage Packet</span>
                <code>@StageId</code>
            </div>
            <dl class="packet-list">
                <div>
                    <dt>Goal</dt>
                    <dd>Collect the first load-bearing trip constraints without asking the user to author a plan.</dd>
                </div>
                <div>
                    <dt>Allowed outputs</dt>
                    <dd>emit_form, emit_choice_set, request_approval, defer_slot</dd>
                </div>
                <div>
                    <dt>Authority</dt>
                    <dd>User answers can patch trip constraints. Model inferences require confirmation.</dd>
                </div>
            </dl>
        </article>

        <article class="panel form-panel" id="stage-form">
            <div class="panel-head">
                <span>Generated Form</span>
                <button class="ghost" type="button" @onclick="SaveDraftAsync">Save draft</button>
            </div>
            <div class="field-grid">
                <label data-required="true">
                    <span>Trip purpose</span>
                    <select @bind="TripPurpose">
                        <option value="vacation">Vacation</option>
                        <option value="business">Business</option>
                        <option value="funeral">Funeral / family obligation</option>
                        <option value="family_support">Helping family</option>
                        <option value="mixed">Mixed purpose</option>
                    </select>
                </label>
                <label data-required="true">
                    <span>Country</span>
                    <input @bind="Country" />
                </label>
                <label data-required="true">
                    <span>Start date</span>
                    <input type="date" @bind="StartDate" />
                </label>
                <label data-required="true">
                    <span>End date</span>
                    <input type="date" @bind="EndDate" />
                </label>
                <label>
                    <span>Pace</span>
                    <select @bind="Pace">
                        <option value="low_cognitive_load">Low cognitive load</option>
                        <option value="balanced">Balanced</option>
                        <option value="packed">Packed</option>
                    </select>
                </label>
            </div>
        </article>

        <article class="panel choice-panel">
            <div class="panel-head">
                <span>Choice Collapse</span>
                <small>small-model owned after fidelity gate</small>
            </div>
            <div class="choice-list">
                @foreach (var option in DinnerStrategies)
                {
                    <button class="choice-card @(SelectedDinnerStrategy == option.Id ? "selected" : "")"
                            type="button"
                            @onclick="() => SelectedDinnerStrategy = option.Id">
                        <strong>@option.Title</strong>
                        <span>@option.Summary</span>
                        <code>@option.Id</code>
                    </button>
                }
            </div>
        </article>

        <article class="panel approval-panel">
            <div class="panel-head">
                <span>Approval Gate</span>
                <small>mocked commit action</small>
            </div>
            <p>
                Holds, bookings, and spend actions require a generated approval request
                plus a user token before an adapter can execute.
            </p>
            <button class="approve" type="button" @onclick="ApproveMockHold">
                Generate mock approval token
            </button>
            @if (!string.IsNullOrWhiteSpace(ApprovalToken))
            {
                <p class="token">Approval token: <code>@ApprovalToken</code></p>
            }
        </article>

        <article class="panel trace-panel">
            <div class="panel-head">
                <span>Evidence Trace Preview</span>
                <small>claim-ledger required</small>
            </div>
            <ol>
                <li>User-owned trip purpose: @TripPurpose</li>
                <li>User-owned country: @Country</li>
                <li>Selected dinner strategy candidate: @SelectedDinnerStrategy</li>
                <li>Approval state: @(string.IsNullOrWhiteSpace(ApprovalToken) ? "not approved" : "approved for mock hold")</li>
            </ol>
        </article>
    </section>
</main>

@code {
    private const string StageId = "slot_collection.demo";
    private IJSObjectReference? module;
    private int RequiredCount;

    private string TripPurpose { get; set; } = "vacation";
    private string Country { get; set; } = "Japan";
    private DateTime StartDate { get; set; } = new(2026, 10, 5);
    private DateTime EndDate { get; set; } = new(2026, 10, 19);
    private string Pace { get; set; } = "balanced";
    private string SelectedDinnerStrategy { get; set; } = "dinner_mixed";
    private string ApprovalToken { get; set; } = "";

    private static readonly ChoiceOption[] DinnerStrategies =
    [
        new("dinner_reserved", "Reserve standout dinners", "Best when dining is a core part of the trip and timing can be protected."),
        new("dinner_mixed", "Mix bookings and flexible meals", "Keeps a few high-value reservations while preserving energy and spontaneity."),
        new("dinner_flexible", "Mostly casual finds", "Lower planning load and fewer commitments, with weaker guarantee for high-demand spots.")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/forms.js");
        await module.InvokeVoidAsync("focusFirstField", "#stage-form");
        RequiredCount = await module.InvokeAsync<int>("requiredFieldCount", "#stage-form");
        StateHasChanged();
    }

    private async Task SaveDraftAsync()
    {
        if (module is null) return;

        var values = new Dictionary<string, object?>
        {
            ["tripPurpose"] = TripPurpose,
            ["country"] = Country,
            ["startDate"] = StartDate.ToString("yyyy-MM-dd"),
            ["endDate"] = EndDate.ToString("yyyy-MM-dd"),
            ["pace"] = Pace,
            ["selectedDinnerStrategy"] = SelectedDinnerStrategy
        };

        await module.InvokeVoidAsync("saveDraft", StageId, values);
    }

    private void ApproveMockHold()
    {
        ApprovalToken = $"mock-approval-{DateTimeOffset.UtcNow:yyyyMMddHHmmss}";
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }

    private sealed record ChoiceOption(string Id, string Title, string Summary);
}
